# === Supabase (required for live / fast queries) ===
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Project Settings → API → service_role (server only — NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Ingestion ===
CRON_SECRET=change-me-to-a-random-string
NCBI_API_KEY=
INGEST_SCHEDULE=0 3 * * 0

# === Netlify ===
# Set all above in Netlify → Site → Environment variables
