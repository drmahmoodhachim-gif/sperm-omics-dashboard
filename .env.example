# === Supabase — use a DEDICATED project or sperm_omics schema ===
# See STANDALONE_DB.md for setup
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_SCHEMA=sperm_omics

# === Access control (required for production) ===
# Generate AUTH_SECRET: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_secure_password
# Optional extra approved users: user2:pass2;user3:pass3
# AUTH_USERS=collaborator:their_password;reviewer:another_password

# === Ingestion ===
CRON_SECRET=change-me-to-a-random-string
NCBI_API_KEY=
INGEST_SCHEDULE=0 3 * * 0

# === Netlify ===
# Set all above in Netlify → Site → Environment variables
